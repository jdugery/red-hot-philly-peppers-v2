---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const homeEntries = await getCollection("home");
const home = homeEntries[0].data;

const peppers = await getCollection("peppers");
const featuredPeppers = peppers.slice(0, 3);
---

<MainLayout title="Red Hot Philly Peppers">
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">{home.eyebrow}</p>

      <h1 class="hero-title">{home.headline}</h1>

      <p class="hero-description">
        {home.description}
      </p>

      <div class="hero-actions">
        <a class="button primary" href="#varieties">Explore varieties</a>
        <a class="button secondary" href="#about">Our story</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="image-placeholder">
        <span>Featured pepper photo</span>
        <small>We will add your picture here</small>
      </div>
    </div>
  </section>

  <section class="intro" id="about">
    <p class="eyebrow">Small farm. Serious peppers.</p>

    <h2>{home.aboutTitle}</h2>

    <p>{home.aboutText}</p>
  </section>

  <section class="varieties" id="varieties">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Featured collection</p>
        <h2>Pepper varieties</h2>
      </div>

      <a href="/peppers">View all varieties →</a>
    </div>

    <div class="pepper-grid">
      {
        featuredPeppers.map((pepper) => (
          <a class="pepper-card" href={`/peppers/${pepper.id}`}>
            <div class="card-image">
              {
                pepper.data.image ? (
                  <img
                    src={pepper.data.image}
                    alt={pepper.data.name}
                  />
                ) : (
                  <span>Photo coming soon</span>
                )
              }
            </div>

            <div class="card-content">
              <p class="heat">{pepper.data.heat}</p>

              <h3>{pepper.data.name}</h3>

              <p>{pepper.data.description}</p>

              <span>View variety →</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="contact" id="contact">
    <p class="eyebrow">Stay connected</p>

    <h2>{home.contactTitle}</h2>

    <p>{home.contactText}</p>

    <a class="button light" href="mailto:johnny@redhotphillypeppers.com">
      Contact us
    </a>
  </section>
</MainLayout>

<style>
.hero-title {
  white-space: pre-line;
}

.pepper-card {
  display: block;
  text-decoration: none;
  color: inherit;
}
.card-image {
  width: 100%;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  border-radius: 10px;
}
.card-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center center;
  display: block;
}
</style>