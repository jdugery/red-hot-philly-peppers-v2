---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";

const homeEntries = await getCollection("home");
const home = homeEntries[0].data;

const featuredPeppers = [
  {
    name: "Sugar Rush Stripey",
    heat: "25,000–50,000 SHU",
    description: "Sweet, tropical flavor with striking striped fruit.",
  },
  {
    name: "7 Pot Primo",
    heat: "1,000,000+ SHU",
    description: "An extremely hot pepper with a distinctive pointed tail.",
  },
  {
    name: "Rezha Macedonian",
    heat: "Mild–Medium",
    description: "A rare heirloom pepper known for its deeply textured skin.",
  },
];
---

<MainLayout title="Red Hot Philly Peppers">
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">{home.eyebrow}</p>

      <h1 class="hero-title">{home.headline}</h1>

      <p class="hero-description">
        {home.description}
      </p>

      <div class="hero-actions">
        <a class="button primary" href="#varieties">Explore varieties</a>
        <a class="button secondary" href="#about">Our story</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="image-placeholder">
        <span>Featured pepper photo</span>
        <small>We will add your picture here</small>
      </div>
    </div>
  </section>

  <section class="intro" id="about">
    <p class="eyebrow">Small farm. Serious peppers.</p>

    <h2>{home.aboutTitle}</h2>

    <p>{home.aboutText}</p>
  </section>

  <section class="varieties" id="varieties">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Featured collection</p>
        <h2>Pepper varieties</h2>
      </div>

      <a href="/peppers">View all varieties →</a>
    </div>

    <div class="pepper-grid">
      {
        featuredPeppers.map((pepper) => (
          <article class="pepper-card">
            <div class="card-image">Photo coming soon</div>

            <div class="card-content">
              <p class="heat">{pepper.heat}</p>
              <h3>{pepper.name}</h3>
              <p>{pepper.description}</p>
              <a href="/peppers">View variety →</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="contact" id="contact">
    <p class="eyebrow">Stay connected</p>

    <h2>{home.contactTitle}</h2>

    <p>{home.contactText}</p>

    <a class="button light" href="mailto:hello@redhotphillypeppers.com">
      Contact us
    </a>
  </section>
</MainLayout>

<style>
  .hero-title {
    white-space: pre-line;
  }
</style>