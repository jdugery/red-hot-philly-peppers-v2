
---
import { getCollection } from "astro:content";

const peppers = await getCollection("peppers");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Pepper Varieties | Red Hot Philly Peppers</title>
  </head>

  <body>
    <header>
      <a href="/">Red Hot Philly Peppers</a>

      <nav>
        <a href="/">Home</a>
        <a href="/peppers">Varieties</a>
      </nav>
    </header>

    <main>
      <section class="heading">
        <p>Our collection</p>
        <h1>Pepper varieties</h1>
        <span>
          Specialty, heirloom, and superhot peppers grown in the Philadelphia
          area.
        </span>
      </section>

      <section class="grid">
  {
    peppers.map((pepper) => (
      <article>
        <div class="image">Photo coming soon</div>

        <div class="content">
          <p class="heat">{pepper.data.heat}</p>
          <h2>{pepper.data.name}</h2>
          <p class="species">{pepper.data.species}</p>
          <p>{pepper.data.description}</p>

          {pepper.data.color && (
            <dl>
              <div>
                <dt>Color</dt>
                <dd>{pepper.data.color}</dd>
              </div>
            </dl>
          )}
        </div>
      </article>
    ))
  }
</section>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: #f6f3eb;
    color: #111311;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  header {
    width: min(1200px, calc(100% - 40px));
    min-height: 90px;
    margin: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-weight: 750;
  }

  nav {
    display: flex;
    gap: 28px;
    font-size: 14px;
  }

  nav a:hover {
    color: #d53024;
  }

  main {
    width: min(1200px, calc(100% - 40px));
    margin: auto;
    padding: 70px 0 120px;
  }

  .heading {
    max-width: 760px;
    margin-bottom: 60px;
  }

  .heading > p {
    margin: 0 0 16px;
    color: #d53024;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 22px;
    font-size: clamp(52px, 7vw, 84px);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }

  .heading span {
    color: #686d68;
    font-size: 19px;
    line-height: 1.65;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  article {
    overflow: hidden;
    border: 1px solid #dedfd9;
    border-radius: 6px;
    background: white;
  }

  .image {
    min-height: 270px;
    display: grid;
    place-items: center;
    background: #e3e6df;
    color: #686d68;
    font-size: 13px;
  }

  .content {
    padding: 26px;
  }

  .heat {
    margin: 0 0 10px;
    color: #d53024;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    font-size: 26px;
  }

  .species {
    margin-top: 8px;
    color: #264c35;
    font-style: italic;
  }

  .content > p:last-of-type {
    color: #686d68;
    line-height: 1.6;
  }

  dl {
    margin: 24px 0 0;
    padding-top: 18px;
    border-top: 1px solid #dedfd9;
  }

  dl div {
    display: flex;
    justify-content: space-between;
    gap: 20px;
  }

  dt {
    color: #686d68;
  }

  dd {
    margin: 0;
    font-weight: 700;
    text-align: right;
  }

  @media (max-width: 850px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
