---
const { title = "Red Hot Philly Peppers" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta
      name="description"
      content="Red Hot Philly Peppers grows specialty, heirloom, and superhot pepper varieties in the Philadelphia area."
    />

    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
     <a class="logo" href="/">
  <img
    class="logo-mark"
    src="/apple-touch-icon.png"
    alt="Red Hot Philly Peppers logo"
  />

  <span class="logo-text">
    <strong>Red Hot Philly Peppers</strong>
  </span>
</a>

      <nav>
        <a href="/#varieties">Varieties</a>
        <a href="/#about">About</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Red Hot Philly Peppers</p>
      <p>Philadelphia, Pennsylvania</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --black: #241917;
    --cream: #f4e9e2;
    --white: #fffaf7;

    --red: #b52b2b;
    --red-dark: #861d1d;
    --red-light: #d34a3e;
    --red-soft: #f0d4ce;
    --red-pale: #faebe7;

    --green: #304638;

    --muted: #75645e;
    --border: #dec9c0;

    --shadow:
      0 18px 50px rgba(84, 27, 23, 0.1);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      radial-gradient(
        circle at 90% 4%,
        rgba(181, 43, 43, 0.13),
        transparent 28%
      ),
      radial-gradient(
        circle at 5% 32%,
        rgba(211, 74, 62, 0.07),
        transparent 24%
      ),
      linear-gradient(180deg, #f9f0eb 0%, #f1e2da 100%);
    color: var(--black);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  main {
    min-height: 70vh;
  }

  .site-header {
    position: relative;
    z-index: 10;
    width: min(1200px, calc(100% - 40px));
    min-height: 84px;
    margin: 20px auto 0;
    padding: 0 25px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid rgba(181, 43, 43, 0.14);
    border-radius: 18px;
    background: rgba(255, 250, 247, 0.82);
    box-shadow: 0 10px 35px rgba(84, 27, 23, 0.07);
    backdrop-filter: blur(14px);
  }

  .logo {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}

.logo-mark {
  width: 62px;
  height: 62px;
  display: block;
  flex-shrink: 0;
  border-radius: 50%;
  border: 2px solid rgba(181, 43, 43, 0.18);
  object-fit: cover;
  box-shadow: 0 8px 22px rgba(134, 29, 29, 0.18);
}

.logo-text {
  display: flex;
  align-items: center;
}

.logo-text strong {
  margin: 0;
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.04em;
  white-space: nowrap;
  color: var(--black);
}

  nav {
    display: flex;
    gap: 30px;
    font-size: 14px;
    font-weight: 750;
  }

  nav a {
    position: relative;
    padding: 10px 0;
  }

  nav a::after {
    position: absolute;
    right: 0;
    bottom: 3px;
    left: 0;
    height: 2px;
    background: var(--red);
    content: "";
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  nav a:hover {
    color: var(--red);
  }

  nav a:hover::after {
    transform: scaleX(1);
  }

  .hero {
    width: min(1200px, calc(100% - 40px));
    min-height: 650px;
    margin: auto;
    padding: 75px 0 100px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: 70px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--red);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0.17em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(52px, 7vw, 92px);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  h2,
  h3 {
    color: var(--black);
  }

  .hero-description {
    max-width: 590px;
    margin: 29px 0 0;
    color: var(--muted);
    font-size: 19px;
    line-height: 1.68;
  }

  .hero-actions {
    margin-top: 38px;
    display: flex;
    gap: 13px;
  }

  .button {
    min-height: 52px;
    padding: 0 25px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 800;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .primary {
    background: linear-gradient(135deg, var(--red-light), var(--red-dark));
    color: white;
    box-shadow: 0 12px 28px rgba(181, 43, 43, 0.25);
  }

  .primary:hover {
    box-shadow: 0 16px 34px rgba(181, 43, 43, 0.34);
  }

  .secondary {
    border: 1px solid rgba(134, 29, 29, 0.34);
    background: rgba(255, 250, 247, 0.55);
    color: var(--red-dark);
  }

  .secondary:hover {
    background: var(--red-pale);
  }

  .hero-visual {
    min-height: 520px;
  }

  .image-placeholder {
    height: 100%;
    min-height: 520px;
    padding: 42px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        rgba(79, 16, 16, 0.18),
        rgba(181, 43, 43, 0.58)
      ),
      var(--red-dark);
    color: white;
    box-shadow: 0 30px 80px rgba(84, 27, 23, 0.24);
  }

  .image-placeholder span {
    font-size: 27px;
    font-weight: 800;
  }

  .image-placeholder small {
    margin-top: 9px;
    opacity: 0.76;
  }

  .intro {
    padding: 120px 20px;
    border-top: 1px solid rgba(181, 43, 43, 0.08);
    border-bottom: 1px solid rgba(181, 43, 43, 0.08);
    background:
      linear-gradient(
        135deg,
        rgba(255, 250, 247, 0.95),
        rgba(250, 235, 231, 0.9)
      );
    text-align: center;
  }

  .intro h2,
  .section-heading h2,
  .contact h2 {
    margin: 0;
    font-size: clamp(38px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .intro > p:last-child {
    max-width: 720px;
    margin: 29px auto 0;
    color: var(--muted);
    font-size: 18px;
    line-height: 1.8;
  }

  .varieties {
    width: min(1200px, calc(100% - 40px));
    margin: auto;
    padding: 120px 0;
  }

  .section-heading {
    margin-bottom: 46px;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 30px;
  }

  .section-heading > a {
    color: var(--red);
    font-weight: 800;
  }

  .section-heading > a:hover {
    color: var(--red-dark);
  }

  .pepper-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .pepper-card {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(255, 250, 247, 0.92);
    box-shadow: 0 12px 35px rgba(84, 27, 23, 0.07);
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .pepper-card:hover {
    border-color: rgba(181, 43, 43, 0.35);
    box-shadow: 0 22px 48px rgba(134, 29, 29, 0.17);
    transform: translateY(-7px);
  }

  .card-image {
    min-height: 270px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(circle at center, #fff7f2, #ead7ce);
    color: var(--muted);
    font-size: 13px;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    min-height: 270px;
    display: block;
    object-fit: contain;
    object-position: center;
  }

  .card-content {
    padding: 27px;
    border-top: 1px solid rgba(181, 43, 43, 0.08);
  }

  .heat {
    margin: 0 0 11px;
    color: var(--red);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .card-content h3 {
    margin: 0;
    font-size: 25px;
  }

  .card-content > p:not(.heat) {
    min-height: 72px;
    color: var(--muted);
    line-height: 1.58;
  }

  .card-content a,
  .card-content > span {
    color: var(--red-dark);
    font-size: 14px;
    font-weight: 800;
  }

  .contact {
    padding: 125px 20px;
    background:
      radial-gradient(
        circle at 15% 15%,
        rgba(255, 255, 255, 0.08),
        transparent 25%
      ),
      linear-gradient(135deg, #8f2020, #4f1517);
    color: white;
    text-align: center;
  }

  .contact h2 {
    color: white;
  }

  .contact .eyebrow {
    color: #ffc1b8;
  }

  .contact > p:not(.eyebrow) {
    max-width: 650px;
    margin: 27px auto 33px;
    color: rgba(255, 255, 255, 0.76);
    font-size: 18px;
    line-height: 1.7;
  }

  .light {
    background: var(--white);
    color: var(--red-dark);
    box-shadow: 0 12px 30px rgba(35, 9, 10, 0.2);
  }

  .light:hover {
    background: var(--red-pale);
  }

  footer {
    padding: 35px max(20px, calc((100% - 1160px) / 2));
    display: flex;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    background: #291416;
    color: rgba(255, 255, 255, 0.66);
    font-size: 13px;
  }

  footer p {
    margin: 0;
  }

  @media (max-width: 850px) {
    .site-header {
      min-height: 76px;
      margin-top: 12px;
      padding: 0 18px;
    }

    nav {
      display: none;
    }

    .hero {
      grid-template-columns: 1fr;
      gap: 45px;
      padding-top: 50px;
    }

    .hero-visual,
    .image-placeholder {
      min-height: 400px;
    }

    .pepper-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 520px) {
    .site-header {
      width: min(100% - 24px, 1200px);
    }

    .logo-mark {
  width: 52px;
  height: 52px;
}

.logo-text strong {
  font-size: 1.35rem;
}

    .hero {
      width: min(100% - 28px, 1200px);
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .varieties {
      width: min(100% - 28px, 1200px);
    }

    footer {
      gap: 12px;
      flex-direction: column;
      text-align: center;
    }
  }
</style>